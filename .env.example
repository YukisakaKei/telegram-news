# 复制此文件为 .env 或写入 GitHub Secrets

# DeepSeek API Key (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Telegram Bot Token (从 @BotFather 获取)
TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Telegram Chat ID (从 @userinfobot 获取)
TG_CHAT_ID=123456789

# RSS 订阅源，逗号分隔
RSS_FEEDS=https://hnrss.org/frontpage?count=20,https://techcrunch.com/feed/,https://www.theverge.com/rss/index.xml,https://openai.com/news/rss.xml

# 代理（国内访问 Telegram API 需要，可选）
# HTTPS_PROXY=http://127.0.0.1:7890

# 兴趣关键词，逗号分隔
INTERESTS=AI,Agent,Automation,Python,Startup,SaaS
